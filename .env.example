# Configuración de la API
TITULO_API=API de Productos
DESCRIPCION_API=Backend del parcial para productos, categorías e ingredientes
VERSION_API=1.0.0
PREFIJO_API=/api
HOST_API=0.0.0.0
PUERTO_API=8000
MODO_DEBUG=true
ORIGENES_PERMITIDOS=*

# Configuración de PostgreSQL
ESQUEMA_BASE_DE_DATOS=postgresql+psycopg
USUARIO_BASE_DE_DATOS=postgres
CONTRASENA_BASE_DE_DATOS=cambiar_esta_contrasena
HOST_BASE_DE_DATOS=localhost
PUERTO_BASE_DE_DATOS=5432
NOMBRE_BASE_DE_DATOS=parcial_programacion_4

# Alternativa: si preferís usar una URL completa, descomentá esta variable
# URL_BASE_DE_DATOS=postgresql+psycopg://postgres:tu_contrasena@localhost:5432/parcial_programacion_4
